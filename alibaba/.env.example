# Alibaba Cloud Function Compute - Environment Variables
# Copy this file to .env and fill in your values

# AWS API Gateway webhook URL for invoice processing
AWS_WEBHOOK_URL=https://YOUR-API-ID.execute-api.ap-southeast-1.amazonaws.com/dev/api/webhook/invoice-parsed

# DashScope API keys (get from https://dashscope.console.aliyun.com/)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_DOC_API_KEY=sk-your-dashscope-doc-api-key-here

# ------------------------------------------------------------------------------
# Flexible AI Model Configuration
# ------------------------------------------------------------------------------
# API strategy: 'openai-compatible' (default, recommended) or 'sdk' (legacy).
# The OpenAI-compatible strategy uses standard HTTP requests and supports
# model fallback chains. The SDK strategy uses the older DashScope Python SDK.
DASHSCOPE_API_STRATEGY=openai-compatible

# Vision model for image inputs (JPG, PNG).
# Recommended: qwen-vl-max  (best accuracy, lowest hallucination)
# Fallbacks:   qwen-vl-plus (balanced), qwen-vl-ocr (legacy OCR-optimized)
DASHSCOPE_VISION_MODEL=qwen-vl-max

# Text model for PDF inputs (text extracted via PyPDF2).
# Recommended: qwen-plus (default) or qwen-max (best reasoning)
DASHSCOPE_DOC_MODEL=qwen-plus

# Base URL for the DashScope OpenAI-compatible endpoint.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_DOC_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
